datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String         @id @default(cuid())
  matricula       String?        @unique
  email           String?        @unique
  passwordHash    String
  role            String         // "superadmin" | "socio_admin" | "alumno"
  firstName       String?
  lastName        String?
  phone           String?
  createdAt       DateTime       @default(now())
  socioFormador   SocioFormador? @relation(fields: [socioFormadorId], references: [id])
  socioFormadorId String?
  inscription     Inscription?
}

model PreregisteredMatricula {
  id         String   @id @default(cuid())
  matricula  String
  nombre     String?
  email      String?
  fairId     String
  fair       Fair     @relation(fields: [fairId], references: [id])
  importedAt DateTime @default(now())
  @@unique([matricula, fairId])
}

model SocioFormador {
  id           String    @id @default(cuid())
  name         String
  contactEmail String
  logo         String?
  description  String
  status       String    @default("Activo")
  createdAt    DateTime  @default(now())
  users        User[]
  projects     Project[]
}

model Period {
  id          String       @id @default(cuid())
  name        String
  fairPeriods FairPeriod[]
  projects    Project[]
}

model Fair {
  id         String                   @id @default(cuid())
  name       String
  isActive   Boolean                  @default(false)
  createdAt  DateTime                 @default(now())
  periods    FairPeriod[]
  matriculas PreregisteredMatricula[]
}

model FairPeriod {
  fair     Fair   @relation(fields: [fairId], references: [id])
  fairId   String
  period   Period @relation(fields: [periodId], references: [id])
  periodId String
  @@id([fairId, periodId])
}

model Project {
  id              String            @id @default(cuid())
  title           String
  description     String
  location        String
  totalSlots      Int
  remainingSlots  Int
  status          String            @default("Publicado")
  qrToken         String?           @unique
  createdAt       DateTime          @default(now())
  socioFormador   SocioFormador     @relation(fields: [socioFormadorId], references: [id])
  socioFormadorId String
  period          Period            @relation(fields: [periodId], references: [id])
  periodId        String
  inscriptions    Inscription[]
  codes           InscriptionCode[]
}

model InscriptionCode {
  id        String    @id @default(cuid())
  code      String    @unique
  project   Project   @relation(fields: [projectId], references: [id])
  projectId String
  matricula String
  usedAt    DateTime?
  usedBy    String?
  createdAt DateTime  @default(now())
}

model Inscription {
  id        String   @id @default(cuid())
  alumno    User     @relation(fields: [alumnoId], references: [id])
  alumnoId  String   @unique
  project   Project  @relation(fields: [projectId], references: [id])
  projectId String
  status    String   @default("Inscrito")
  createdAt DateTime @default(now())
}

model ActionLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  details   String?
  createdAt DateTime @default(now())
}
