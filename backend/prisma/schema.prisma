datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  role           String        // "superadmin" | "org_admin" | "volunteer"
  emailVerified  Boolean       @default(false)
  firstName      String?
  lastName       String?
  phone          String?
  community      String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  signups        Signup[]
}

model Organization {
  id            String        @id @default(cuid())
  name          String
  contactEmail  String
  logo          String?
  description   String
  status        String        @default("Pending") // Pending | Approved | Rejected | Disabled
  createdAt     DateTime      @default(now())
  users         User[]
  opportunities Opportunity[]
}

model Opportunity {
  id             String       @id @default(cuid())
  title          String
  description    String
  location       String
  startDate      DateTime
  endDate        DateTime
  totalSlots     Int
  remainingSlots Int
  status         String       @default("Draft") // Draft | Published | Closed | Full
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  signups        Signup[]
}

model Signup {
  id            String      @id @default(cuid())
  volunteer     User        @relation(fields: [volunteerId], references: [id])
  volunteerId   String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  opportunityId String
  status        String      @default("Registrado") // Registrado | Completado | Cancelado
  createdAt     DateTime    @default(now())

  @@unique([volunteerId, opportunityId])
}

model ActionLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  details   String?
  createdAt DateTime @default(now())
}
