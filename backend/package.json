{
  "name": "voluntarios-backend",
  "version": "1.0.0",
  "description": "Backend para la plataforma de voluntarios",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "db:migrate": "npx prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "setup": "npm install && npx prisma migrate dev --name init && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.10.2",
    "resend": "^6.9.3"
  }
}
